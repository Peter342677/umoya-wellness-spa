<section class="hero" style="min-height: 92vh;">
  <div class="container">
    <div class="hero__content hero__content--center">
      <span class="badge hero__eyebrow" data-reveal="fade">Deposit Received</span>
      <h1 class="hero__title" data-split-text="immediate">Thank <em>You</em></h1>
      <p class="hero__subhead">
        <% if (details && details.serviceName) { %>
          We've received your <%= site.booking.depositAmountFormatted %> deposit for <strong><%= details.serviceName %></strong>.
        <% } else { %>
          We've received your <%= site.booking.depositAmountFormatted %> deposit.
        <% } %>
        We'll be in touch within one business day to confirm your exact appointment time. The remaining balance is paid at your visit.
      </p>
      <div class="hero__ctas">
        <a href="/" class="btn btn--primary btn--magnetic" data-cursor="view">Back to Home</a>
        <a href="/services" class="link-underline" data-cursor="view">Explore more services</a>
      </div>
    </div>
  </div>
</section>
