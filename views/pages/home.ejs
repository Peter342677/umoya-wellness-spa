<!-- ============ HERO ============ -->
<section class="hero">
  <div class="hero__bg" aria-hidden="true">
    <!-- Image fallback: shown while the video loads, on data-saver, and for prefers-reduced-motion -->
    <img src="/assets/images/hero/hero-bg.jpg" alt="" loading="eager" />
    <!-- PLACEHOLDER: swap for real footage of the Umoya treatment room when available -->
    <video class="hero__video" autoplay muted loop playsinline preload="metadata"
      poster="/assets/images/hero/hero-bg.jpg" disablepictureinpicture>
      <source src="/assets/video/hero.mp4" type="video/mp4" />
    </video>
  </div>
  <div class="container">
    <div class="hero__content hero__content--center">
      <span class="badge hero__eyebrow" data-reveal="fade">Now Open</span>
      <h1 class="hero__title" data-split-text="immediate">Umoya <em>Wellness Spa</em></h1>
      <p class="hero__subhead">Body Contouring &amp; Medical Wellness in South Salt Lake. A sanctuary of rest, renewal, and radiance, led by a registered nurse who takes your goals seriously.</p>
      <div class="hero__ctas">
        <a href="/book" class="btn btn--primary btn--magnetic" data-cursor="book">Book Now</a>
        <a href="/services" class="btn btn--outline btn--magnetic" data-cursor="view">Explore Services</a>
      </div>
    </div>
  </div>
  <div class="hero__scroll-hint" aria-hidden="true">Breathe</div>
</section>

<!-- ============ PLAN YOUR VISIT ============ -->
<section class="section section--dark">
  <div class="container">
    <div class="section-head section-head--center" data-reveal>
      <span class="eyebrow">Plan Your Visit</span>
      <h2 class="heading-lg">Find Your Way to <em>Stillness</em></h2>
    </div>
    <div class="info-tiles" data-reveal-group>
      <div class="info-tile">
        <div class="info-tile__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 21s-7-5.6-7-11a7 7 0 0 1 14 0c0 5.4-7 11-7 11Z"/><circle cx="12" cy="10" r="2.6"/></svg>
        </div>
        <p class="info-tile__label">Address</p>
        <p class="info-tile__value">2253 S State St Ste #7<br/>South Salt Lake, UT 84115</p>
      </div>
      <div class="info-tile">
        <div class="info-tile__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.2 2"/></svg>
        </div>
        <p class="info-tile__label">Hours</p>
        <div class="info-tile__value">
          <% site.contact.hours.forEach(function(h) { %>
            <div class="hours-row"><span><%= h.days %></span><span><%= h.time %></span></div>
          <% }) %>
        </div>
      </div>
      <div class="info-tile">
        <div class="info-tile__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 4h4l2 5-2.5 1.5a12 12 0 0 0 5 5L15 13l5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2Z"/></svg>
        </div>
        <p class="info-tile__label">Call Us</p>
        <p class="info-tile__value"><a href="<%= site.contact.phoneHref %>" class="link-underline"><%= site.contact.phone %></a><br/><a href="/contact" class="link-underline text-accent">Get directions &rarr;</a></p>
      </div>
    </div>
  </div>
</section>

<!-- ============ WELLNESS, THOUGHTFULLY DELIVERED ============ -->
<section class="section section--light">
  <div class="container grid-2col">
    <div class="img-reveal mask-reveal" data-reveal data-parallax style="aspect-ratio: 4 / 5; border-radius: var(--radius-md);">
      <img src="/assets/images/about/founder.jpg" alt="Cheryl Johnson, RN-BSN-FAACM, founder of Umoya Wellness Spa" loading="lazy" />
    </div>
    <div data-reveal>
      <span class="eyebrow">Our Approach</span>
      <h2 class="heading-lg" data-split-text>Wellness, <em>Thoughtfully Delivered</em></h2>
      <p class="text-muted" style="margin-top:1.4rem; max-width:46ch;">Umoya is a Zulu word meaning air, breath, and spirit, and that is exactly what we built this space to feel like. Founded by Cheryl Johnson, RN-BSN-FAACM, Umoya pairs the credibility of a clinical practice with the calm of a true sanctuary.</p>
      <p class="text-muted" style="margin-top:1rem; max-width:46ch;">Every visit begins with a real conversation, not a sales pitch. Cheryl builds each treatment plan around your body, your goals, and honest expectations, because results you can trust start with guidance you can trust.</p>
      <a href="/about" class="btn btn--outline btn--magnetic" style="margin-top:2rem;" data-cursor="view">Meet Cheryl</a>
    </div>
  </div>
</section>

<!-- ============ SIGNATURE SERVICES ============ -->
<section class="section section--dark">
  <div class="container">
    <div class="section-head section-head--split" data-reveal>
      <div>
        <span class="eyebrow">Our Signature Services</span>
        <h2 class="heading-lg" data-split-text>Sculpt. Restore. <em>Radiate.</em></h2>
      </div>
      <a href="/services" class="link-underline" data-cursor="view">View all services &rarr;</a>
    </div>
    <div class="card-grid" data-reveal-group>
      <% services.forEach(function(s) { %>
        <a href="/services/<%= s.slug %>" class="service-card" data-cursor="view">
          <!-- PLACEHOLDER: swap for real treatment photography -->
          <img class="service-card__img" src="<%= s.heroImage %>" alt="<%= s.name %>" loading="lazy" />
          <div class="service-card__body">
            <span class="service-card__category"><%= s.category %></span>
            <h3 class="service-card__title"><%= s.name %></h3>
            <p class="service-card__text"><%= s.tagline %></p>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- ============ TESTIMONIALS ============ -->
<section class="section section--dark" style="padding-top:0;">
  <div class="container">
    <div class="section-head section-head--center" data-reveal>
      <span class="eyebrow">Happy Clients</span>
      <h2 class="heading-lg">Kind Words, <em>Honestly Earned</em></h2>
    </div>
    <div class="testimonials" data-reveal>
      <div class="testimonials__track">
        <% testimonials.forEach(function(t) { %>
          <div class="testimonial-card">
            <div class="testimonial-card__stars" aria-label="<%= t.rating %> out of 5 stars">
              <%- '&#9733;'.repeat(t.rating) %>
            </div>
            <p class="testimonial-card__text">&ldquo;<%= t.text %>&rdquo;</p>
            <div class="testimonial-card__author">
              <span class="testimonial-card__avatar" aria-hidden="true"><%= t.name.charAt(0) %></span>
              <div>
                <p class="testimonial-card__name"><%= t.name %></p>
                <p class="testimonial-card__source">Google Review</p>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <div class="testimonials__nav"></div>
    </div>
  </div>
</section>

<!-- ============ FINAL CTA ============ -->
<section class="cta-band cta-band--final">
  <div class="container cta-band__content" data-reveal>
    <span class="eyebrow">Your Sanctuary Awaits</span>
    <h2 class="heading-lg cta-band__title">Ready to begin your <em>wellness journey?</em></h2>
    <p class="cta-band__text">Consultations are unhurried, honest, and built around you. Reserve your visit today.</p>
    <a href="/book" class="btn btn--primary btn--magnetic" data-cursor="book">Book Now</a>
  </div>
</section>
