<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__brand">
      <a href="/" class="site-footer__logo" aria-label="<%= site.brand.name %> home">
        <%- include('logo', { variant: 'gold', showTag: true }) %>
      </a>
      <p class="site-footer__mission"><%= site.brand.tagline %></p>
      <div class="site-footer__social">
        <a href="<%= site.social.instagram %>" aria-label="Instagram (<%= site.social.instagramHandle %>)" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.6"/><circle cx="17.2" cy="6.8" r="1.2" fill="currentColor"/></svg>
        </a>
      </div>
    </div>

    <nav class="site-footer__col" aria-label="Quick links">
      <h3 class="site-footer__heading">Quick Links</h3>
      <ul>
        <li><a href="/about" class="link-underline">About Us</a></li>
        <li><a href="/services" class="link-underline">Services</a></li>
        <li><a href="/packages" class="link-underline">Packages</a></li>
        <li><a href="/concierge-healthcare" class="link-underline">Concierge Healthcare</a></li>
        <li><a href="/learn-more" class="link-underline">Learn More</a></li>
        <li><a href="/news" class="link-underline">News &amp; Journal</a></li>
        <li><a href="/contact" class="link-underline">Contact</a></li>
      </ul>
    </nav>

    <nav class="site-footer__col" aria-label="Services">
      <h3 class="site-footer__heading">Services</h3>
      <ul>
        <% site.nav.services.forEach(function(item) { %>
          <li><a href="/services/<%= item.slug %>" class="link-underline"><%= item.shortName %></a></li>
        <% }) %>
      </ul>
    </nav>

    <div class="site-footer__col">
      <h3 class="site-footer__heading">Hours</h3>
      <div class="site-footer__hours">
        <% site.contact.hours.forEach(function(h) { %>
          <div class="hours-row"><span><%= h.days %></span><span><%= h.time %></span></div>
        <% }) %>
      </div>

      <h3 class="site-footer__heading site-footer__heading--spaced">Visit Us</h3>
      <ul class="site-footer__contact">
        <li><%= site.contact.address %></li>
        <li><a href="<%= site.contact.phoneHref %>" class="link-underline"><%= site.contact.phone %></a></li>
        <li><a href="mailto:<%= site.contact.email %>" class="link-underline"><%= site.contact.email %></a></li>
        <li><a href="<%= site.social.instagram %>" class="link-underline" target="_blank" rel="noopener noreferrer"><%= site.social.instagramHandle %></a></li>
      </ul>

      <p style="margin-top:1.8rem;">
        <a href="/book" class="btn btn--outline btn--magnetic" data-cursor="book">Book Now</a>
      </p>
      <p style="margin-top:0.9rem; font-size:0.8rem;">
        <a href="<%= site.bookingUrl %>" target="_blank" rel="noopener noreferrer" class="link-underline" data-cursor="view">View live availability on Vagaro</a>
      </p>
      <p style="margin-top:1.1rem; font-size:0.78rem; color: var(--text-on-dark-muted);">For medspa services, flexible financing is available through Affirm, Puurk, and HFA.</p>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="container site-footer__bottom-row">
      <p>&copy; <%= new Date().getFullYear() %> <%= site.brand.name %>. All rights reserved.</p>
      <p class="site-footer__credit">Designed with care, for those who deserve the best.</p>
    </div>
  </div>
</footer>
