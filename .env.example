PORT=3070

# Optional SMTP config. If unset, contact form submissions and booking
# notifications are logged to data/submissions/*.json instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_TO_EMAIL=umoyahelp@gmail.com

# Stripe (booking deposit checkout). Get these from the Stripe Dashboard:
# https://dashboard.stripe.com/test/apikeys (secret + publishable keys)
# https://dashboard.stripe.com/test/webhooks (webhook signing secret)
# Without these, /book still renders but shows "booking payments are
# temporarily unavailable" instead of taking a deposit.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Calendar (live availability + auto-synced appointments). Create a
# service account in Google Cloud Console, enable the Calendar API, and
# share the target calendar with the service account's email address
# ("Make changes to events" permission). Without these, /book falls back to
# the plain preferred date/time fields and no calendar events are created.
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY accepts either the raw PEM (with literal
# \n escapes, fine for a local .env) or - recommended for hosting-panel env
# var UIs, which can mangle backslashes/newlines on paste - a base64
# encoding of that same PEM: node -e "console.log(Buffer.from(require('./key.json').private_key).toString('base64'))"
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=umoyahelp@gmail.com
