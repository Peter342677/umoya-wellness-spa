PORT=3070

# Optional SMTP config. If unset, contact form submissions and booking
# notifications are logged to data/submissions/*.json instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_TO_EMAIL=umoyahelp@gmail.com

# Stripe (booking deposit checkout). Get these from the Stripe Dashboard:
# https://dashboard.stripe.com/test/apikeys (secret + publishable keys)
# https://dashboard.stripe.com/test/webhooks (webhook signing secret)
# Without these, /book still renders but shows "booking payments are
# temporarily unavailable" instead of taking a deposit.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
